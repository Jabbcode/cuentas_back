generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())

  accounts      Account[]
  categories    Category[]
  transactions  Transaction[]
  fixedExpenses FixedExpense[]
  debts         Debt[]
  debtPayments  DebtPayment[]
}

model Account {
  id        String   @id @default(uuid())
  name      String
  type      String   // "cash", "bank", "credit_card"
  balance   Decimal  @default(0)
  currency  String   @default("EUR")
  color     String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Credit card specific fields (null if not credit card)
  creditLimit   Decimal? // Credit limit (e.g., 5000.00)
  cutoffDay     Int?     // Statement closing day (1-31)
  paymentDueDay Int?     // Payment due day (1-31)

  transactions       Transaction[]
  fixedExpenses      FixedExpense[]
  creditCardPayments CreditCardPayment[]
  debtPayments       DebtPayment[]
  createdAt          DateTime @default(now())

  @@index([userId])
}

model Category {
  id     String  @id @default(uuid())
  name   String
  type   String  // "expense" | "income"
  icon   String?
  color  String?
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions  Transaction[]
  fixedExpenses FixedExpense[]

  @@index([userId])
}

model Transaction {
  id          String   @id @default(uuid())
  amount      Decimal
  type        String   // "expense" | "income"
  description String?
  date        DateTime @default(now())

  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fixedExpenseId String?
  fixedExpense   FixedExpense? @relation(fields: [fixedExpenseId], references: [id], onDelete: SetNull)

  creditCardPayment CreditCardPayment?
  debtPayment       DebtPayment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([accountId])
  @@index([categoryId])
  @@index([date])
}

model FixedExpense {
  id          String   @id @default(uuid())
  name        String
  amount      Decimal
  type        String   // "expense" | "income"
  dueDay      Int      // 1-31
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  description String?

  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, type, sortOrder])
}

model CreditCardPayment {
  id          String   @id @default(uuid())
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  amount      Decimal
  paymentDate DateTime
  periodStart DateTime // Start of the paid period
  periodEnd   DateTime // End of the paid period

  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([accountId])
  @@index([paymentDate])
}

model Debt {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Basic information
  creditor        String   // Name of the creditor (e.g., "Juan", "Banco BBVA")
  description     String   // Description/concept of the debt
  totalAmount     Decimal  // Original total amount of the debt
  remainingAmount Decimal  // Remaining amount to pay

  // Interest (optional)
  interestRate Decimal? // Interest rate
  interestType String?  // "fixed" | "percentage"

  // Dates
  startDate DateTime  @default(now())
  dueDate   DateTime? // Payment deadline (optional)

  // Status
  status String @default("active") // "active" | "paid" | "overdue"

  // Payments
  payments DebtPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
}

model DebtPayment {
  id     String @id @default(uuid())
  debtId String
  debt   Debt   @relation(fields: [debtId], references: [id], onDelete: Cascade)

  amount    Decimal // Total payment amount (principal + interest)
  principal Decimal // Amount that goes to principal
  interest  Decimal // Amount that goes to interest

  // Account from which the payment was made
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // Associated transaction
  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  paymentDate DateTime @default(now())
  notes       String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([debtId])
  @@index([userId])
  @@index([paymentDate])
}
